# PostgreSQL
POSTGRES_DB=defectdojo
POSTGRES_USER=defectdojo
POSTGRES_PASSWORD=defectdojo

# DefectDojo
DD_SECRET_KEY=change-me-in-production-use-a-long-random-string
DD_CREDENTIAL_AES_256_KEY=0000000000000000
DD_ALLOWED_HOSTS=*
DD_DEBUG=false

# Admin account (used only on first initialization)
DD_ADMIN_USER=admin
DD_ADMIN_MAIL=admin@example.com
DD_ADMIN_PASSWORD=admin
DD_ADMIN_FIRST_NAME=Admin
DD_ADMIN_LAST_NAME=User

# Ports
DEFECTDOJO_PORT=8080

# Scanner — config file
# config.toml is mounted automatically at /app/config.toml (see docker-compose.scanner.yml).
# Run `cp config.example.toml config.toml` to create it; all scan parameters live there.
# Override the path (e.g. to use a separate prod config) with VS_CONFIG.
# VS_CONFIG=/app/prod.toml

# Scanner — env overrides (take precedence over config.toml values)
VS_MODE=passive
VS_TARGETS=
VS_DEFECTDOJO_API_KEY=
VS_DEFECTDOJO_PRODUCT=

# Authenticated scanning (global defaults; per-target overrides require config.toml)
# VS_AUTH_BEARER_TOKEN=
# VS_AUTH_USERNAME=
# VS_AUTH_PASSWORD=
# VS_AUTH_LOGIN_URL=

# Plugin system
# VS_PLUGINS_ENABLED=true
# VS_PLUGINS_DIRS=/opt/company-scanners

# LLM analysis (OpenAI-compatible)
# Standard OpenAI env vars are also honoured as fallbacks:
OPENAI_API_KEY=
# set for non-OpenAI endpoints (Ollama, vLLM, OpenRouter, etc.)
OPENAI_BASE_URL=
# required when LLM is active, e.g. gpt-4o or llama3.2
VS_LLM_MODEL=
# auto|true|false — auto = on when api_key present
VS_LLM_ENABLED=auto
# VS_LLM_TEMPERATURE=0.2
# VS_LLM_MAX_TOKENS=4096
# LLM features (per-feature on/off, e.g. VS_LLM_FEATURE_EXECUTE_POC=true)
# enable only inside container for PoC execution
VS_LLM_FEATURE_EXECUTE_POC=true